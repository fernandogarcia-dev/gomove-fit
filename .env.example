# GoMove — Environment Variables
# Copy to .env and fill in values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/<SUPABASE_PROJECT_ID>/settings/api

# Frontend (Vite) — must match Supabase → Vercel integration prefix: VITE_
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# Supabase CLI / setup scripts only — never add VITE_ prefix, but SUPABASE_SERVICE_ROLE_KEY
# also needs to be set on Vercel (Production + Preview) for the /api/* serverless functions below.
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
SUPABASE_PROJECT_REGION=sa-east-1
SUPABASE_DB_PASS=your_db_password
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Initial admin setup (scripts/setup-admin.mjs only)
ADMIN_EMAIL=admin@gomove.fit
ADMIN_PASSWORD=your_secure_password

# GoMove PRO — Stripe (server-side only, set on Vercel → Project Settings → Environment Variables)
# See README.md "GoMove PRO / payments" for the full setup walkthrough.
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
# Optional publishable key if you add client-side Stripe Elements later
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_...
# Optional — defaults to https://gomove.fit if unset. Vercel Preview deployments use the
# request's Origin header automatically, so this is mostly for local `vercel dev`.
APP_URL=https://gomove.fit

# Google Analytics (optional — add to Vercel Production)
# Create GTM container: https://tagmanager.google.com
VITE_GTM_ID=GTM-XXXXXXX
# GA4 measurement ID — configure as a tag inside GTM (recommended)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Search Console verification: https://search.google.com/search-console
VITE_GOOGLE_SITE_VERIFICATION=your_verification_code

# Google AdSense (optional — add after approval)
# Publisher ID from https://www.google.com/adsense
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Create ad units in AdSense → Ads → By ad unit, then paste slot IDs:
VITE_ADSENSE_SLOT_BLOG_HUB_TOP=0000000000
VITE_ADSENSE_SLOT_BLOG_HUB_MID=0000000000
VITE_ADSENSE_SLOT_BLOG_FEED=0000000000
VITE_ADSENSE_SLOT_ARTICLE_TOP=0000000000
VITE_ADSENSE_SLOT_ARTICLE_MID=0000000000
VITE_ADSENSE_SLOT_ARTICLE_BOTTOM=0000000000
