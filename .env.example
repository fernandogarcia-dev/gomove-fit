# GoMove — Environment Variables
# Copy to .env and fill in values from your Supabase project dashboard:
# https://supabase.com/dashboard/project/<SUPABASE_PROJECT_ID>/settings/api

# Frontend (Vite) — must match Supabase → Vercel integration prefix: VITE_
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# Supabase CLI only — never add these to Vercel
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
SUPABASE_PROJECT_REGION=sa-east-1
SUPABASE_DB_PASS=your_db_password
